<div class="flex gap-6 h-dvh overflow-hidden bg-gray-50">
  <!-- 左ペイン：会話リスト -->
  <aside class="w-80 p-4 border-r border-slate-200 bg-white/70 backdrop-blur flex flex-col">
    <form action="<%= conversations_path %>" method="get" class="flex gap-2">
      <input type="text" name="q" value="<%= h(@q) %>" placeholder="検索（タイトル）"
             class="input-text flex-1" />
      <button type="submit" class="btn-secondary h-9 px-3">検索</button>
    </form>

    <%= form_with url: conversations_path, method: :post, class: "mt-3", local: true, data: { turbo: false } do %>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <button type="submit" class="btn-primary w-full h-9">＋ 新規会話</button>
    <% end %>

    <ul class="mt-4 flex-1 overflow-y-auto space-y-2 text-sm">
      <% @conversations.each do |c| %>
        <li>
          <%= link_to conversation_path(c, q: @q.presence), class: "block px-2 py-1 rounded hover:bg-slate-100 #{c.id == @conversation.id ? 'font-bold bg-slate-200' : ''}", data: {turbo: false} do %>
            <%= h(c.title.presence || '（無題）') %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </aside>

  <!-- 右ペイン：会話内容 -->
  <main class="flex-1 flex flex-col">
    <header class="h-15 bg-white/80 backdrop-blur flex items-center justify-between px-6 border-b border-slate-200 overflow-visible z-20">
      <h1 class="flex items-center gap-3 text-lg font-semibold text-slate-800">
        <span><%= h(@conversation.title.presence || '（無題）') %></span>
        <%= form_with url: retitle_conversation_path(@conversation), method: :post, local: true, data: { turbo: false }, class: "inline" do %>
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <button type="submit" class="btn-secondary h-8 px-3 text-xs">タイトル再生成</button>
        <% end %>
        <%= link_to "設定変更", edit_conversation_path(@conversation), class: "btn-secondary h-8 px-3 py-2 text-xs", data: { turbo: false } %>
      </h1>
      <div class="flex items-center gap-2">
        <!-- Chapter 10: エクスポート / 共有 / アーカイブ -->
        <details class="relative">
          <summary class="btn-secondary h-8 px-3 text-xs cursor-pointer flex items-center">エクスポート</summary>
          <ul class="absolute right-0 mt-1 bg-white border rounded-lg shadow text-sm z-50">
            <li><a href="<%= export_conversation_path(@conversation, f: :md) %>" class="block px-3 py-2 hover:bg-slate-50">Markdown</a></li>
            <li><a href="<%= export_conversation_path(@conversation, f: :html) %>" class="block px-3 py-2 hover:bg-slate-50">HTML</a></li>
            <li><a href="<%= export_conversation_path(@conversation, f: :pdf) %>" class="block px-3 py-2 hover:bg-slate-50">PDF</a></li>
          </ul>
        </details>

        <form id="share-form" action="<%= share_conversation_path(@conversation) %>" method="post" data-turbo="false">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <button type="submit" class="btn-secondary h-8 px-3 text-xs">共有リンク</button>
        </form>

        <form action="<%= archive_conversation_path(@conversation) %>" method="post" data-turbo="false">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <button type="submit" class="btn-secondary h-8 px-3 text-xs">アーカイブ</button>
        </form>

        <form id="stop-form" action="/messages/stop" method="post" class="flex items-center">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <input type="hidden" id="conversation_id" name="conversation_id" value="<%= @conversation.id %>">
          <button type="submit" id="stop" class="btn-primary h-9 px-4" disabled>停止</button>
        </form>
      </div>
    </header>

    <!-- メッセージログ -->
    <div id="log"
         class="flex-1 card p-4 flex flex-col gap-3 md:gap-4 overflow-y-auto"
         style="min-height:0;">
      <% @conversation.messages.order(:created_at).each do |m| %>
        <div class="flex w-full <%= m.role == 'user' ? 'justify-end' : 'justify-start' %>">
          <div>
            <div class="<%= m.role == 'user' ? 'role-user' : 'role-assistant' %> mb-1">
              <%= m.role.upcase %>
            </div>
            <div class="<%= m.role == 'user' ? 'bubble-right markdown-body' : 'bubble-left markdown-body' %>">
              <%= h m.content %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 入力フォーム -->
    <footer class="bg-gray-50 backdrop-blur px-6 py-4 border-t border-slate-200">
      <form id="form" action="/messages" method="post" class="w-full card p-4" enctype="multipart/form-data" data-turbo="false">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token, id: "message_authenticity_token" %>
        <input type="hidden" id="conversation_id" name="conversation_id" value="<%= @conversation.id %>">

        <label for="content" class="block text-xs font-semibold text-slate-500 mb-2">メッセージ</label>
        <textarea id="content" name="message[content]" rows="2"
          class="input-text resize-none"
          placeholder="Shift+Enterで改行 / Enterで送信"
          style="height:auto;max-height:96px;overflow:auto"></textarea>

        <div class="mt-2 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <p class="text-xs text-slate-500">Enterで送信 / Shift+Enterで改行</p>
            <span id="tok" class="text-xs text-slate-400"></span>
          </div>
          <button type="button" id="send" class="btn-primary h-10 px-5" onclick="window.handleSendClick(event)">送信</button>
        </div>

        <div class="mt-2 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <button type="button" id="regen" class="btn-secondary h-9 px-4">再生成</button>
            <button type="button" id="edit-last" class="btn-secondary h-9 px-4">編集して再送</button>
          </div>
          <div class="flex items-center gap-2">
            <!-- ファイル添付 -->
            <label for="message_files"
                   class="btn-secondary h-9 px-3 flex items-center cursor-pointer">
              📎 添付
            </label>
            <input type="file" id="message_files" name="message[files][]"
                   multiple accept="application/pdf,image/*" class="hidden">
            <span id="file-count" class="text-xs text-slate-500"></span>
          </div>
        </div>

        <p id="typing-indicator" class="text-xs text-slate-500 mt-2 hidden">
          AIが入力中<span class="dotting"></span>
        </p>
      </form>
    </footer>
  </main>
</div>

<!-- グローバルハンドラー -->
<script>
  window.__appState = {
    initialized: false,
    subscriptionConnected: false,
    errors: []
  }
  
  let generating = false
  let form, area, log, stopBtn, typingEl, cid
  let aiMsgEl, assembling = ""
  
  // DOM 要素の初期化
  function initializeDOM() {
    form = document.getElementById("form")
    area = document.getElementById("content")
    log = document.getElementById("log")
    stopBtn = document.getElementById("stop")
    typingEl = document.getElementById("typing-indicator")
    cid = document.getElementById("conversation_id")?.value
    
    console.log("[Global] DOM initialized, cid:", cid)
    return form && area && log && stopBtn && typingEl
  }
  
  // Form submission handler
  function initFormHandler() {
    if (!form) {
      console.error("[Global] Form not found!")
      return false
    }
    
    console.log("[Global] Adding form submit listener")
    
    form.addEventListener("submit", async (e) => {
      e.preventDefault()
      console.log("[formSubmitHandler] Submit event fired!")
      
      if (generating) {
        console.log("[formSubmitHandler] Skipping: still generating")
        return
      }
      
      const fd = new FormData(form)
      const btn = document.getElementById("send")
      const prev = btn.innerHTML
      btn.disabled = true
      btn.innerHTML = "送信中..."
      
      // Get user message content
      const userContent = fd.get("message[content]") || ""
      
      // Display user message immediately
      if (userContent && window.newRow && window.renderMarkdownSafe) {
        const mine = window.newRow("user")
        if (mine) {
          mine.innerHTML = window.renderMarkdownSafe(userContent.toString())
        }
      } else if (userContent) {
        // Fallback: simple text display if functions not ready
        const mine = document.createElement("div")
        mine.className = "flex w-full justify-end"
        const wrap = document.createElement("div")
        wrap.className = "flex flex-col"
        const role = document.createElement("div")
        role.className = "role-user mb-1"
        role.textContent = "YOU"
        const bubble = document.createElement("div")
        bubble.className = "bubble-right markdown-body"
        bubble.textContent = userContent
        wrap.appendChild(role)
        wrap.appendChild(bubble)
        mine.appendChild(wrap)
        log.appendChild(mine)
        log.scrollTop = log.scrollHeight
      }
      
      try {
        const token = document.getElementById("message_authenticity_token")?.value
        console.log("[formSubmitHandler] Sending to", form.action)
        
        const res = await fetch(form.action, {
          method: "POST",
          headers: {
            "X-CSRF-Token": token
          },
          body: fd
        })
        
        console.log("[formSubmitHandler] Response status:", res.status)
        
        if (!res.ok) {
          throw new Error(`HTTP ${res.status}`)
        }
        
        console.log("[formSubmitHandler] Request successful")
        area.value = ""
        area.focus()
        if (document.getElementById("message_files")) {
          document.getElementById("message_files").value = ""
        }
      } catch (err) {
        console.error("[formSubmitHandler] Error:", err.message)
      } finally {
        btn.disabled = false
        btn.innerHTML = prev
      }
    })
    
    return true
  }
  
  // ActionCable subscription handler
  function initActionCable() {
    console.log("[ActionCable] Initializing ActionCable...")
    console.log("[ActionCable] typeof ActionCable:", typeof ActionCable)
    
    // ActionCable will be set up by the module script
    // Just log that we're ready
    window.__appState.actionCableReady = true
  }
  
  // Handle incoming ActionCable messages
  function handleActionCableMessage(payload) {
    console.log("[Message] Processing event:", payload.event)
    
    if (payload.event === "start") {
      console.log("[Message] START - initializing AI response")
      generating = true
      stopBtn.disabled = false
      aiMsgEl = newRow("assistant")
      assembling = ""
      typingEl.classList.remove("hidden")
      return
    }
    
    if (payload.event === "delta") {
      console.log("[Message] DELTA - received text chunk")
      assembling += payload.body || ""
      renderAssistantLive(aiMsgEl, assembling)
      log.scrollTop = log.scrollHeight
      return
    }
    
    if (payload.event === "done") {
      console.log("[Message] DONE - AI response complete")
      generating = false
      stopBtn.disabled = true
      renderAssistantLive(aiMsgEl, assembling)
      typingEl.classList.add("hidden")
      return
    }
    
    if (payload.event === "error") {
      console.log("[Message] ERROR -", payload.body)
      generating = false
      stopBtn.disabled = true
      appendErrorRetry(payload.body)
      typingEl.classList.add("hidden")
      return
    }
  }
  
  window.handleSendClick = (event) => {
    event.preventDefault()
    console.log("[handleSendClick] button clicked")
    
    if (form) {
      console.log("[handleSendClick] dispatching submit event")
      const submitEvent = new Event("submit", { bubbles: true, cancelable: true })
      form.dispatchEvent(submitEvent)
    }
  }
  
  // Initialize on DOM ready
  document.addEventListener("DOMContentLoaded", () => {
    console.log("[Global] DOMContentLoaded event")
    if (initializeDOM()) {
      initFormHandler()
      initActionCable()
      window.__appState.initialized = true
    }
  })
  
  // If already loaded
  if (document.readyState !== "loading") {
    console.log("[Global] Document already loaded, initializing immediately")
    if (initializeDOM()) {
      initFormHandler()
      // ActionCable init needs to wait a bit for consumer to be available
      setTimeout(initActionCable, 500)
      window.__appState.initialized = true
    }
  }

  // IMEガード
  let composing = false
  area.addEventListener("compositionstart", () => composing = true)
  area.addEventListener("compositionend", () => composing = false)
  area.addEventListener("keydown", (e) => {
    if (e.isComposing || composing) return
    if (e.key === "Enter" && !e.shiftKey) { 
      e.preventDefault()
      form.requestSubmit()
    }
  })

  // ファイル選択表示更新
  function updateFileCount() {
    const fileInput = document.getElementById("message_files")
    const fileCount = document.getElementById("file-count")
    const count = fileInput.files.length
    if (count > 0) {
      fileCount.textContent = `${count}個のファイル`
    } else {
      fileCount.textContent = ""
    }
  }

  document.getElementById("message_files").addEventListener("change", updateFileCount)

  // 停止処理
  const stopForm = document.getElementById("stop-form")
  if (stopForm) {
    stopForm.addEventListener("submit", async (e) => {
      e.preventDefault()
      if (!generating) return
      const token = stopForm.querySelector('input[name="authenticity_token"]').value
      const body = new URLSearchParams({ conversation_id: cid })
      await fetch(stopForm.action, { 
        method: "POST", 
        headers: { 
          "Content-Type": "application/x-www-form-urlencoded", 
          "X-CSRF-Token": token 
        }, 
        body 
      })
    })
  }

  // トークンカウンタ
  function estimateTokens(s) { 
    return Math.ceil((s || '').length / 3.5) 
  }
  const tokenCounter = document.getElementById("tok")
  if (tokenCounter && area) {
    area.addEventListener('input', () => { 
      tokenCounter.textContent = `~${estimateTokens(area.value)} tok` 
    })
  }

  // 再生成 / 編集して再送
  const regenBtn = document.getElementById("regen")
  if (regenBtn) {
    regenBtn.addEventListener("click", async () => {
      await fetch("/messages/regenerate", {
        method: "POST",
        headers: {
          "X-CSRF-Token": document.getElementById("message_authenticity_token").value,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ conversation_id: cid })
      })
    })
  }

  const editLastBtn = document.getElementById("edit-last")
  if (editLastBtn) {
    editLastBtn.addEventListener("click", () => {
      const lastUser = [...document.querySelectorAll(".role-user + .bubble-right")].pop()
      if (lastUser) { 
        area.value = lastUser.textContent.trim()
        area.focus() 
      }
    })
  }

  // 共有リンク処理
  const shareForm = document.getElementById("share-form")
  if (shareForm) {
    shareForm.addEventListener("submit", async (e) => {
      e.preventDefault()
      const form = e.target

      try {
        const token = form.querySelector('input[name="authenticity_token"]').value
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'X-CSRF-Token': token, 'Accept': 'application/json' }
        })

        if (!res.ok) throw new Error("共有リンク作成に失敗しました")
        const json = await res.json()
        console.log(json)

        // クリップボードにコピー
        if (navigator.clipboard) {
          await navigator.clipboard.writeText(json.url)
        }

        alert(`共有リンクをコピーしました\n有効期限: ${json.expires_at}\n${json.url}`)
      } catch (e) {
        console.error(e)
        alert("共有リンク作成に失敗しました")
      }
    })
  }
</script>

<script type="module">
  console.log("[Module] Module script starting, attempting imports...")
  
  try {
    // Try dynamic imports with fallback
    let marked, DOMPurify, hljs, createConsumer
    
    try {
      marked = (await import("marked")).default || await import("marked")
      console.log("[Module] marked imported successfully")
    } catch (e) {
      console.warn("[Module] marked import failed, will use marked from window:", e.message)
      marked = window.marked
    }
    
    try {
      DOMPurify = (await import("dompurify")).default
      console.log("[Module] DOMPurify imported successfully")
    } catch (e) {
      console.warn("[Module] DOMPurify import failed:", e.message)
      DOMPurify = window.DOMPurify
    }
    
    try {
      hljs = (await import("highlight.js")).default
      console.log("[Module] highlight.js imported successfully")
    } catch (e) {
      console.warn("[Module] highlight.js import failed, creating no-op version:", e.message)
      hljs = { highlightElement: () => {} }
    }
    
    try {
      createConsumer = (await import("@rails/actioncable")).createConsumer
      console.log("[Module] createConsumer imported successfully")
    } catch (e) {
      console.error("[Module] createConsumer import CRITICAL FAILED:", e.message)
      throw e
    }
    
    // Save to window for debugging
    window.__moduleLoaded = { marked, DOMPurify, hljs, createConsumer }

    // Make functions globally available for markdown rendering
    window.renderMarkdownSafe = function(text) {
      if (!marked) return text
      try {
        const html = marked.parse(text || "")
        const safe = DOMPurify ? DOMPurify.sanitize(html, { USE_PROFILES: { html: true }}) : html
        const tmp = document.createElement("div")
        tmp.innerHTML = safe
        return tmp.innerHTML
      } catch (e) {
        console.warn("[renderMarkdownSafe] Rendering failed:", e)
        return text
      }
    }

    window.enhanceCodeBlocks = function(container) {
      if (!container || !hljs) return
      try {
        container.querySelectorAll('pre code').forEach((block) => {
          hljs.highlightElement(block)
          window.attachCopyButton(block)
        })
      } catch (e) {
        console.warn("[enhanceCodeBlocks] Enhancement failed:", e)
      }
    }

    window.attachCopyButton = function(codeEl) {
      const pre = codeEl.closest('pre')
      if (!pre || pre.querySelector('.button-copy')) return
      const btn = document.createElement('button')
      btn.className = 'button-copy'
      btn.type = 'button'
      btn.textContent = 'Copy'
      btn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(codeEl.innerText)
        const old = btn.textContent; btn.textContent = 'Copied!'
        setTimeout(() => btn.textContent = old, 800)
      })
      pre.appendChild(btn)
    }

    window.withProvisionalFences = function(text) {
      const fenceCount = (text.match(/```/g) || []).length
      return fenceCount % 2 === 1 ? text + "\n```" : text
    }

    window.renderAssistantLive = function(el, assembling) {
      if (!el) return
      const safeHTML = window.renderMarkdownSafe(window.withProvisionalFences(assembling))
      el.innerHTML = safeHTML
      window.enhanceCodeBlocks(el)
    }

    window.appendErrorRetry = function(reason) {
      const log = document.getElementById("log")
      if (!log) return
      
      const row = document.createElement("div")
      row.className = "flex w-full justify-start"
      const wrap = document.createElement("div")
      wrap.className = "bubble-left bg-red-50 text-red-700 p-2 rounded relative"
      const msg = document.createElement("span")
      msg.textContent = `[error] ${reason} `
      const btn = document.createElement("button")
      btn.type = "button"
      btn.className = "btn-secondary h-7 px-2 ml-2"
      btn.textContent = "再試行"
      btn.addEventListener("click", () => {
        const form = document.getElementById("form")
        if (form) form.requestSubmit()
        row.remove()
      })
      wrap.appendChild(msg)
      wrap.appendChild(btn)
      row.appendChild(wrap)
      log.appendChild(row)
      log.scrollTop = log.scrollHeight
    }

    window.newRow = function(sender) {
      const log = document.getElementById("log")
      if (!log) return null
      
      const row = document.createElement("div")
      row.className = "flex w-full " + (sender === "user" ? "justify-end" : "justify-start")
      const wrap = document.createElement("div")
      wrap.className = "flex flex-col"
      const role = document.createElement("div")
      role.className = (sender === "user") ? "role-user mb-1" : "role-assistant mb-1"
      role.textContent = (sender === "user") ? "YOU" : "ASSISTANT"
      const bubble = document.createElement("div")
      bubble.className = (sender === "user") ? "bubble-right markdown-body" : "bubble-left markdown-body"
      wrap.appendChild(role)
      wrap.appendChild(bubble)
      row.appendChild(wrap)
      log.appendChild(row)
      log.scrollTop = log.scrollHeight
      return bubble
    }

    console.log("[Module] Helper functions exported to window")

    // Setup ActionCable subscription
    console.log("[Module] Setting up ActionCable...")
    const consumer = createConsumer()
    console.log("[Module] Consumer created:", consumer)
    
    const conversationId = document.getElementById("conversation_id")?.value
    console.log("[Module] Conversation ID:", conversationId)
    
    const subscription = consumer.subscriptions.create(
      { channel: "ChatChannel", conversation_id: conversationId || "global" },
      {
        connected() {
          console.log("[ActionCable] Connected to ChatChannel")
          window.__appState.subscriptionConnected = true
        },
        
        disconnected() {
          console.log("[ActionCable] Disconnected from ChatChannel")
          window.__appState.subscriptionConnected = false
        },
        
        received(data) {
          console.log("[ActionCable] Received:", data.event)
          window.handleActionCableMessage(data)
        }
      }
    )
    
    console.log("[Module] ActionCable subscription created")
    window.__appState.actionCableReady = true
    window.__subscription = subscription
    
  } catch (err) {
    console.error("[Module] Setup failed:", err.message, err.stack)
    window.__appState.errors.push(err.message)
    window.__moduleError = err.message
  }
</script>

