<div class="flex gap-6 h-dvh overflow-hidden bg-gray-50">
  <!-- 左ペイン：会話リスト -->
  <aside class="w-80 p-4 border-r border-slate-200 bg-white/70 backdrop-blur flex flex-col">
    <form action="<%= conversations_path %>" method="get" class="flex gap-2">
      <input type="text" name="q" value="<%= h(@q) %>" placeholder="検索（タイトル）"
             class="input-text flex-1" />
      <button type="submit" class="btn-secondary h-9 px-3">検索</button>
    </form>

    <%= form_with url: conversations_path, method: :post, class: "mt-3", local: true, data: { turbo: false } do %>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <button type="submit" class="btn-primary w-full h-9">＋ 新規会話</button>
    <% end %>

    <ul class="mt-4 flex-1 overflow-y-auto space-y-2 text-sm">
      <% @conversations.each do |c| %>
        <li>
          <%= link_to conversation_path(c, q: @q.presence), class: "block px-2 py-1 rounded hover:bg-slate-100 #{c.id == @conversation.id ? 'font-bold bg-slate-200' : ''}", data: {turbo: false} do %>
            <%= h(c.title.presence || '（無題）') %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </aside>

  <!-- 右ペイン：会話内容 -->
  <main class="flex-1 flex flex-col">
    <header class="h-15 bg-white/80 backdrop-blur flex items-center justify-between px-6 border-b border-slate-200">
      <h1 class="flex items-center gap-3 text-lg font-semibold text-slate-800">
        <span><%= h(@conversation.title.presence || '（無題）') %></span>
        <%= form_with url: retitle_conversation_path(@conversation), method: :post, local: true, data: { turbo: false }, class: "inline" do %>
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <button type="submit" class="btn-secondary h-8 px-3 text-xs">タイトル再生成</button>
        <% end %>
        <%= link_to "設定変更", edit_conversation_path(@conversation), class: "btn-secondary h-8 px-3 py-2 text-xs", data: { turbo: false } %>
      </h1>
      <form id="stop-form" action="/messages/stop" method="post" class="flex items-center">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <input type="hidden" id="conversation_id" name="conversation_id" value="<%= @conversation.id %>">
        <button type="submit" id="stop" class="btn-primary h-9 px-4" disabled>停止</button>
      </form>
    </header>

    <!-- メッセージログ -->
    <div id="log"
         class="flex-1 card p-4 flex flex-col gap-3 md:gap-4 overflow-y-auto"
         style="min-height:0;">
      <% @conversation.messages.order(:created_at).each do |m| %>
        <div class="flex w-full <%= m.role == 'user' ? 'justify-end' : 'justify-start' %>">
          <div>
            <div class="<%= m.role == 'user' ? 'role-user' : 'role-assistant' %> mb-1">
              <%= m.role.upcase %>
            </div>
            <div class="<%= m.role == 'user' ? 'bubble-right markdown-body' : 'bubble-left markdown-body' %>">
              <%= h m.content %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 入力フォーム -->
    <footer class="bg-gray-50 backdrop-blur px-6 py-4 border-t border-slate-200">
      <form id="form" action="/messages" method="post" class="w-full card p-4">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token, id: "message_authenticity_token" %>
        <input type="hidden" id="conversation_id" name="conversation_id" value="<%= @conversation.id %>">

        <label for="content" class="block text-xs font-semibold text-slate-500 mb-2">メッセージ</label>
        <textarea id="content" name="message[content]" rows="2"
          class="input-text resize-none"
          placeholder="Shift+Enterで改行 / Enterで送信"
          style="height:auto;max-height:96px;overflow:auto"></textarea>

        <div class="mt-2 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <p class="text-xs text-slate-500">Enterで送信 / Shift+Enterで改行</p>
            <span id="tok" class="text-xs text-slate-400"></span>
          </div>
          <button type="submit" id="send" class="btn-primary h-10 px-5">送信</button>
        </div>

        <div class="mt-2 flex items-center gap-2">
          <button type="button" id="regen" class="btn-secondary h-9 px-4">再生成</button>
          <button type="button" id="edit-last" class="btn-secondary h-9 px-4">編集して再送</button>
        </div>

        <p id="typing-indicator" class="text-xs text-slate-500 mt-2 hidden">
          AIが入力中<span class="dotting"></span>
        </p>
      </form>
    </footer>
  </main>
</div>

<script type="module">
  import { subscribeChat } from "channels/chat_channel"
  import { marked } from "marked"
  import DOMPurify from "dompurify"
  import hljs from "highlight.js"

  const log  = document.getElementById("log")
  const form = document.getElementById("form")
  const stopForm = document.getElementById("stop-form")
  const area = document.getElementById("content")
  const stopBtn = document.getElementById("stop")
  const typingEl = document.getElementById("typing-indicator")
  const cid = document.getElementById("conversation_id").value

  // 初期スクロール
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll('#log .markdown-body').forEach((el) => {
      const raw = el.textContent
      el.innerHTML = renderMarkdownSafe(raw)
      enhanceCodeBlocks(el)
    })
    log.scrollTop = log.scrollHeight
  })

  function newRow(sender) {
    const row = document.createElement("div")
    row.className = "flex w-full " + (sender === "user" ? "justify-end" : "justify-start")
    const wrap = document.createElement("div")
    wrap.className = "flex flex-col"
    const role = document.createElement("div")
    role.className = (sender === "user") ? "role-user mb-1" : "role-assistant mb-1"
    role.textContent = (sender === "user") ? "YOU" : "ASSISTANT"
    const bubble = document.createElement("div")
    bubble.className = (sender === "user") ? "bubble-right markdown-body" : "bubble-left markdown-body"
    wrap.appendChild(role)
    wrap.appendChild(bubble)
    row.appendChild(wrap)
    log.appendChild(row)
    log.scrollTop = log.scrollHeight
    return bubble
  }

  function renderMarkdownSafe(text) {
    const html = marked.parse(text || "")
    const safe = DOMPurify.sanitize(html, { USE_PROFILES: { html: true }})
    const tmp = document.createElement("div")
    tmp.innerHTML = safe
    return tmp.innerHTML
  }

  function enhanceCodeBlocks(container) {
    container.querySelectorAll('pre code').forEach((block) => {
      hljs.highlightElement(block)
      attachCopyButton(block)
    })
  }

  function attachCopyButton(codeEl) {
    const pre = codeEl.closest('pre')
    if (!pre || pre.querySelector('.button-copy')) return
    const btn = document.createElement('button')
    btn.className = 'button-copy'
    btn.type = 'button'
    btn.textContent = 'Copy'
    btn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(codeEl.innerText)
      const old = btn.textContent; btn.textContent = 'Copied!'
      setTimeout(() => btn.textContent = old, 800)
    })
    pre.appendChild(btn)
  }

  function withProvisionalFences(text) {
    const fenceCount = (text.match(/```/g) || []).length
    return fenceCount % 2 === 1 ? text + "\n```" : text
  }

  function renderAssistantLive(el, assembling) {
    const safeHTML = renderMarkdownSafe(withProvisionalFences(assembling))
    el.innerHTML = safeHTML
    enhanceCodeBlocks(el)
  }

  function appendErrorRetry(reason) {
    const row = document.createElement("div")
    row.className = "flex w-full justify-start"
    const wrap = document.createElement("div")
    wrap.className = "bubble-left bg-red-50 text-red-700 p-2 rounded relative"
    const msg = document.createElement("span")
    msg.textContent = `[error] ${reason} `
    const btn = document.createElement("button")
    btn.type = "button"
    btn.className = "btn-secondary h-7 px-2 ml-2"
    btn.textContent = "再試行"
    btn.addEventListener("click", () => {
      form.requestSubmit()
      row.remove()
    })
    wrap.appendChild(msg)
    wrap.appendChild(btn)
    row.appendChild(wrap)
    log.appendChild(row)
    log.scrollTop = log.scrollHeight
  }

  let generating = false
  let assembling = ""
  let aiMsgEl

  subscribeChat(cid, (payload) => {
    if (payload.event === "start") {
      generating = true
      stopBtn.disabled = false
      aiMsgEl = newRow("assistant")
      assembling = ""
      typingEl.classList.remove("hidden")
      return
    }
    if (payload.event === "delta") {
      assembling += payload.body || ""
      renderAssistantLive(aiMsgEl, assembling)
      log.scrollTop = log.scrollHeight
      return
    }
    if (payload.event === "done") {
      generating = false
      stopBtn.disabled = true
      renderAssistantLive(aiMsgEl, assembling)
      typingEl.classList.add("hidden")
      return
    }
    if (payload.event === "error") {
      generating = false
      stopBtn.disabled = true
      appendErrorRetry(payload.body)
      typingEl.classList.add("hidden")
      return
    }
  })

  // IMEガード
  let composing = false
  area.addEventListener("compositionstart", () => composing = true)
  area.addEventListener("compositionend",   () => composing = false)
  area.addEventListener("keydown", (e) => {
    if (e.isComposing || composing) return
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); form.requestSubmit(); }
  })

  // 送信処理
  form.addEventListener("submit", async (e) => {
    e.preventDefault()
    if (generating) return
    const fd = new FormData(form)
    const btn = document.getElementById("send")
    const prev = btn.innerHTML
    btn.disabled = true; btn.innerHTML = "送信中..."
    const mine = newRow("user")
    mine.innerHTML = renderMarkdownSafe((fd.get("message[content]") || "").toString())
    try {
      await fetch(form.action, { method: "POST", headers: { "Accept": "text/vnd.turbo-stream.html" }, body: fd })
      area.value = ""; area.focus()
    } catch {
      appendErrorRetry("送信に失敗しました")
    } finally {
      btn.disabled = false; btn.innerHTML = prev
    }
  })

  // 停止処理
  stopForm.addEventListener("submit", async (e) => {
    e.preventDefault()
    if (!generating) return
    const token = stopForm.querySelector('input[name="authenticity_token"]').value
    const body = new URLSearchParams({ conversation_id: cid })
    await fetch(stopForm.action, { method: "POST", headers: { "Content-Type": "application/x-www-form-urlencoded", "X-CSRF-Token": token }, body })
  })

  // トークンカウンタ
  function estimateTokens(s) { return Math.ceil((s || '').length / 3.5) }
  const tokenCounter = document.getElementById("tok")
  area.addEventListener('input', () => { tokenCounter.textContent = `~${estimateTokens(area.value)} tok` })

  // 再生成 / 編集して再送
  document.getElementById("regen").addEventListener("click", async () => {
    await fetch("/messages/regenerate", {
      method: "POST",
      headers: {
        "X-CSRF-Token": document.getElementById("message_authenticity_token").value,
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ conversation_id: cid })
    })
  })

  document.getElementById("edit-last").addEventListener("click", () => {
    const lastUser = [...document.querySelectorAll(".role-user + .bubble-right")].pop()
    if (lastUser) { area.value = lastUser.textContent.trim(); area.focus() }
  })
</script>
