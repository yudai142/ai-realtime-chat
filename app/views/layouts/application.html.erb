<!DOCTYPE html>
<html>
  <head>
    <title>Realtime Chat</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      :root { --grad: radial-gradient(1200px 400px at 50% -10%, rgba(56,189,248,.25), transparent); }
      body { background: #f8fafc var(--grad) no-repeat; }
    </style>
  </head>
  <body class="h-dvh overflow-hidden text-slate-800">
    <%= yield %>
  </body>
</html>