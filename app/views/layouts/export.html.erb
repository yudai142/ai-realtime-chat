<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title><%= content_for?(:title) ? yield(:title) : "Export" %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <style>
    /* フォントはサーバ側に CJK を入れておく（Noto Sans CJK JP など） */
    body {
      background:#f8fafc; color:#0f172a;
      font:16px/1.9 "Noto Sans CJK JP","Hiragino Kaku Gothic ProN","Yu Gothic",Meiryo,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,"Apple Color Emoji","Segoe UI Emoji";
    }
    .page{
      max-width:72ch; margin:48px auto; padding:40px 28px; background:#fff;
      border:1px solid #e2e8f0; border-radius:16px;
      /* wkhtmltopdf は box-shadow も弱いが軽い影は出ることが多い */
      box-shadow:0 6px 24px rgba(15,23,42,.06);
    }
    .page h1{font-size:30px; line-height:1.25; margin:0 0 16px;}
    .page h2{font-size:22px; line-height:1.35; margin:36px 0 12px;}
    .page h3{font-size:18px; line-height:1.4;  margin:24px 0 8px;}
    .meta{color:#64748b; font-size:14px;}

    .msg{padding:18px 0; border-top:1px dashed #e2e8f0;}
    .msg:first-child{border-top:0; padding-top:0;}
    .pill{
      display:inline-block; padding:2px 8px; border-radius:999px; font-size:12px; font-weight:600;
      border:1px solid #e2e8f0; color:#64748b; background:#f8fafc; vertical-align:middle;
      margin-right:8px; /* gap の代替 */
    }
    .meta-inline{display:inline-block; vertical-align:middle; color:#64748b; font-size:14px;}

    /* Markdown */
    .markdown-body img{max-width:100%; height:auto;}
    .markdown-body p, .markdown-body li{line-height:1.9;}
    .markdown-body blockquote{margin:16px 0; padding:12px 16px; border-left:3px solid #cbd5e1; background:#f8fafc;}
    .markdown-body hr{border:0; border-top:1px solid #e2e8f0; margin:24px 0;}
    .markdown-body table{width:100%; border-collapse:collapse; margin:16px 0;}
    .markdown-body th,.markdown-body td{border:1px solid #e2e8f0; padding:8px 10px; text-align:left;}
    .markdown-body code:not(pre code){
      background:#f1f5f9; border:1px solid #e2e8f0; border-radius:6px; padding:2px 6px;
    }
    .markdown-body pre{
      margin:16px 0; border:1px solid #e2e8f0; border-radius:12px; overflow:auto; background:#0b1020;
    }
    .markdown-body pre code{display:block; padding:16px 18px; color:#e5e7eb; font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;}

    /* 印刷体裁（wkhtmltopdf にも効く） */
    @media print{
      body{background:#fff;}
      .page{box-shadow:none; border:0; margin:0; padding:0; max-width:none;}
      .msg{page-break-inside:avoid;}
      a[href]:after{content:" (" attr(href) ")"; font-size:12px; color:#64748b;}
    }
  </style>
</head>
<body>
  <main class="page">
    <%= yield %>
  </main>
</body>
</html>
