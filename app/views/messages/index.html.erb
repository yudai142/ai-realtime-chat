
<div class="relative h-dvh overflow-hidden bg-gray-50">
  <header class="h-14 bg-white/80 backdrop-blur">
    <div class="w-full mx-auto max-w-7xl xl:max-w-[90rem] h-full px-4 py-3 md:px-6 lg:px-8 flex items-center justify-between">
      <h1 class="text-lg font-semibold text-slate-800">Realtime AI Chat (Echo)</h1>
      <form id="stop-form" action="/messages/stop" method="post" class="h-full flex items-center">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="hidden" id="conversation_id" name="conversation_id" value="global">
        <button type="submit" id="stop" class="btn-primary h-9 px-4" disabled>停止</button>
      </form>
    </div>
  </header>

  <main class="mt-3 px-4 md:px-6 lg:px-8">
    <div class="w-full mx-auto max-w-7xl xl:max-w-[90rem]">
      <div id="log"
           class="card p-4 flex flex-col gap-3 md:gap-4 overflow-y-auto"
           style="height: calc(100dvh - 310px);">
      </div>
    </div>
  </main>

  <footer class="absolute inset-x-0 h-auto bg-gray-50 backdrop-blur mt-2">
    <div class="w-full mx-auto max-w-7xl xl:max-w-[90rem] h-full px-4 md:px-6 lg:px-8 flex items-center">
      <form id="form" action="/messages" method="post" class="w-full card p-4 mt-4">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="hidden" name="conversation_id" value="global">

        <label for="content" class="block text-xs font-semibold text-slate-500 mb-2">メッセージ</label>
        <textarea id="content" name="message[content]" rows="2"
          class="input-text resize-none"
          placeholder="Shift+Enterで改行 / Enterで送信"
          style="height:auto;max-height:96px;overflow:auto"></textarea>

        <div class="mt-2 flex items-center justify-between">
          <p class="text-xs text-slate-500">Enterで送信 / Shift+Enterで改行</p>
          <button type="submit" id="send" class="btn-primary h-10 px-5">送信</button>
        </div>
      </form>
    </div>
  </footer>
</div>

<script type="module">
  import { subscribeChat } from "channels/chat_channel"

  const log = document.getElementById("log")
  const form = document.getElementById("form")
  const area = document.getElementById("content")
  const cid = document.getElementById("conversation_id").value

  function append({ sender, content }) {
    const row = document.createElement("div")
    row.className = "flex w-full " + (sender === "user" ? "justify-end" : "justify-start")

    const wrap = document.createElement("div")
    wrap.className = "flex w-full " + (sender === "user" ? "justify-end" : "justify-start")

    const role = document.createElement("div")
    role.className = (sender === "user") ? "role-user mb-1" : "role-assistant mb-1"
    role.textContent = (sender === "user") ? "YOU" : "ASSISTANT"

    const bubble = document.createElement("div")
    bubble.className = (sender === "user") ? "bubble-right" : "bubble-left"
    bubble.textContent = content

    wrap.appendChild(role)
    wrap.appendChild(bubble)
    row.appendChild(wrap)
    log.appendChild(row)
    log.scrollTop = log.scrollHeight
  }

  subscribeChat(cid, append)

  let composing = false
  area.addEventListener("compositionstart", () => { composing = true })
  area.addEventListener("compositionend", () => { composing = false })

  area.addEventListener("keydown", (e) => {
    if (e.isComposing || composing) return
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); form.requestSubmit(); }
  })

  form.addEventListener("submit", async (e) => {
    e.preventDefault()
    const fd = new FormData(form)
    const btn = form.querySelector("button[type='submit']")
    const prev = btn.innerHTML
    btn.disabled = true; btn.innerHTML = "送信中..."
    try {
      await fetch(form.action, { method: "POST", headers: { "Accept": "text/vnd.turbo-stream.html" }, body: fd })
      area.value = ""; area.focus()
    } finally {
      btn.disabled = false; btn.innerHTML = prev
    }
  })
</script>
